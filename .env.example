# Login credentials for the Choga content hub
ADMIN_USER=Choga
ADMIN_PASS=7007

# Used to sign login sessions (JWT). Set this to a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Where saved settings are stored on disk.
# On Railway, attach a Volume and mount it here so data survives redeploys.
DATA_DIR=/data

# Instagram API with Instagram Login (developers.facebook.com -> App -> Instagram -> Settings)
# Used by the "ربط إنستغرام" button on the Accounts tab.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
